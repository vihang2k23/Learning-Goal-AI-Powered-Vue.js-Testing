{
  "name": "vue-testing-fundamentals",
  "version": "1.0.0",
  "description": "Vue.js Testing Fundamentals with Vitest and Playwright",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "test": "node ./node_modules/vitest/vitest.mjs",
    "test:ui": "node ./node_modules/vitest/vitest.mjs --ui",
    "test:run": "node ./node_modules/vitest/vitest.mjs run",
    "test:coverage": "node ./node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
    "test:e2e:ui": "node ./node_modules/@playwright/test/cli.js test --ui",
    "test:e2e:debug": "node ./node_modules/@playwright/test/cli.js test --debug",
    "test:e2e:install": "node ./node_modules/@playwright/test/cli.js install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^22.1.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.5",
    "vue": "^3.5.27"
  }
}
